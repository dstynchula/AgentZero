# --- LLM provider (provider-agnostic) ---
# One of: openai | anthropic
AGENTZERO_LLM_PROVIDER=openai
AGENTZERO_LLM_MODEL=gpt-4o-mini
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Search profile ---
AGENTZERO_SEARCH_TERMS=software engineer
AGENTZERO_LOCATIONS=Remote
AGENTZERO_RESULTS_WANTED=50
AGENTZERO_HOURS_OLD=168
AGENTZERO_COUNTRY_INDEED=USA

# --- Scraping ---
# Comma-separated proxies, e.g. host:port,host:port (leave blank for none)
AGENTZERO_PROXIES=
AGENTZERO_MAX_CONCURRENCY=4

# --- Storage ---
AGENTZERO_DB_PATH=data/agentzero.db

# --- Google integration ---
# Path to OAuth client secret (Desktop app) and where the token is cached
AGENTZERO_GOOGLE_CLIENT_SECRET=client_secret.json
AGENTZERO_GOOGLE_TOKEN_PATH=token.json
AGENTZERO_SHEET_ID=
