# --- LLM provider (pick ONE provider; set only that provider's API key) ---
# AGENTZERO_LLM_PROVIDER selects which key is used: openai | anthropic
AGENTZERO_LLM_PROVIDER=openai

# Budget default for ingest + search + rank (see docs/COST_AND_MODELS.md):
AGENTZERO_LLM_MODEL=gpt-5-nano
# Higher quality rank/repair (more cost): gpt-4o-mini
# Rank-only bump: gpt-4.1-mini

# If provider=openai (default), set this and leave ANTHROPIC_API_KEY unset:
OPENAI_API_KEY=

# If provider=anthropic, set this and leave OPENAI_API_KEY unset:
# ANTHROPIC_API_KEY=

# Cap job description length in rank prompts (full text stays in DB). Lowers cost.
AGENTZERO_RANK_DESCRIPTION_MAX_CHARS=2500

# --- Search profile (used when no résumé in resume/, or as fallback) ---
AGENTZERO_SEARCH_TERMS=software engineer
AGENTZERO_LOCATIONS=Remote
# Remote-only: scrape United States + remote filter; drop on-site/hybrid listings (default true)
AGENTZERO_REMOTE_ONLY=true
AGENTZERO_RESULTS_WANTED=50
AGENTZERO_HOURS_OLD=168
AGENTZERO_COUNTRY_INDEED=USA
# Minimum acceptable comp (USD/year). Scraper skips listings whose posted range
# top is below this (comp_max, or comp_min when no max). Also set each scrape run.
# AGENTZERO_SALARY_MIN=230000
# Prompt for titles/locations/salary before each scrape (set false for CI)
AGENTZERO_SEARCH_INTERACTIVE=true

# --- Scraping ---
# Comma-separated proxies, e.g. host:port (leave blank for none)
AGENTZERO_PROXIES=
AGENTZERO_MAX_CONCURRENCY=4
# Parallel LLM classification (rank) calls — raise for faster rank_and_sync (watch API rate limits)
AGENTZERO_RANK_MAX_CONCURRENCY=8
# Minimum match_score for Google Sheet / CSV export (applied jobs always export). 0 = disable.
AGENTZERO_MIN_MATCH_SCORE=0.75

# Secondary enrichment (scripts/enrich_jobs.py): fetch job URLs + Glassdoor lookup
AGENTZERO_ENRICH_FETCH_DETAILS=true
AGENTZERO_ENRICH_GLASSDOOR_LOOKUP=true
AGENTZERO_ENRICH_DELAY_SECONDS=2
AGENTZERO_ENRICH_MAX_CONCURRENCY=6
# DuckDuckGo web search: company size, Glassdoor snippets, careers page URL
AGENTZERO_ENRICH_WEB_SEARCH=true
AGENTZERO_ENRICH_WEB_SEARCH_MAX_RESULTS=8
AGENTZERO_ENRICH_WEB_SEARCH_DELAY_SECONDS=2

# Five core sources — sequential with delay between each fetch:
# Browser: Indeed, LinkedIn, Glassdoor (Playwright)
# JobSpy:  Google, ZipRecruiter (HTTP; Zip may 403 without proxies — log and continue)
AGENTZERO_SCRAPE_BROWSER_SITES=indeed,linkedin,glassdoor
AGENTZERO_SCRAPE_SITES=google,zip_recruiter
AGENTZERO_SCRAPE_PRIMARY_QUERY_ONLY=true
AGENTZERO_SCRAPE_DELAY_SECONDS=3
# Headless=false — visible Chrome window (use with SCRAPE_BROWSER_CHANNEL=chrome)
AGENTZERO_SCRAPE_BROWSER_HEADLESS=false
# Pause scrape until you press Enter after solving CAPTCHA in the browser
AGENTZERO_SCRAPE_BROWSER_PAUSE_FOR_CAPTCHA=true
# Persistent browser profile (cookies survive between runs) — treat as secrets; gitignored
AGENTZERO_SCRAPE_BROWSER_PROFILE_DIR=data/indeed_browser_profile
# Use installed Google Chrome — recommended for CAPTCHA (not bundled Chromium)
AGENTZERO_SCRAPE_BROWSER_CHANNEL=chrome

# Fail fast when login wall detected (skip 5-min CAPTCHA wait)
# AGENTZERO_SCRAPE_SESSION_PREFLIGHT=true
# Attach to Chrome with --remote-debugging-port=9222 (Indeed/Glassdoor; see scripts/launch_chrome_cdp.ps1)
# AGENTZERO_SCRAPE_CDP_URL=http://127.0.0.1:9222
# AGENTZERO_SCRAPE_CDP_SITES=indeed,glassdoor
# AGENTZERO_SCRAPE_CDP_AUTO_LAUNCH=true

# --- Docker (optional; see docs/DOCKER.md) ---
# Host Chrome via CDP from inside the container:
# AGENTZERO_SCRAPE_CDP_URL=http://host.docker.internal:9222
# AGENTZERO_SCRAPE_CDP_AUTO_LAUNCH=false
# AGENTZERO_CDP_ALLOW_DOCKER_HOST=true
# AGENTZERO_SEARCH_INTERACTIVE=false
# Build stall warning when docker output is silent (seconds):
# AGENTZERO_BUILD_STALL_SEC=180
# Imported cookie exports per site (Cookie-Editor → import_browser_cookies.py)
# AGENTZERO_SCRAPE_STORAGE_STATE_DIR=data/browser_storage_state
# AGENTZERO_LINKEDIN_FETCH_DESCRIPTION=false

# --- Storage ---
AGENTZERO_DB_PATH=data/agentzero.db

# --- Web UI (optional; docker compose up web) ---
# AGENTZERO_WEB_ENABLED=true
# AGENTZERO_WEB_HOST=0.0.0.0
# AGENTZERO_WEB_PORT=8080

# Tracker: local web UI (recommended). From repo root:
#   docker compose up web
# Open http://localhost:8080 — browse, edit status/notes, soft-reject roles.
# Optional CSV backup: python -c "from agentzero.storage.csv_export import export_csv; ..."
